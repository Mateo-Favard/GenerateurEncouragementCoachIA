# === AudioCoach KeepFit Configuration ===

# LLM
COACH_LLM_MODEL_PATH=models/llm/Qwen3-4B-Q4_K_M.gguf
COACH_LLM_N_CTX=4096
COACH_LLM_N_THREADS=4
COACH_LLM_MAX_TOKENS=2048
COACH_LLM_TEMPERATURE=0.7

# TTS
COACH_TTS_MODEL_PATH=models/tts/fr_FR-siwis-medium.onnx
COACH_TTS_SAMPLE_RATE=22050
COACH_TTS_SPEAKER_ID=0

# Server
COACH_HOST=0.0.0.0
COACH_PORT=8000
COACH_LOG_LEVEL=info

# Thread pool
COACH_MAX_WORKERS=4

# Temp files
COACH_TEMP_DIR=/tmp/audiocoach
